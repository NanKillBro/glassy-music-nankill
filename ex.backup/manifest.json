{
   "action": {
      "default_popup": "action/default_popup.html"
   },
   "background": {
      "service_worker": "background/service_worker.js",
      "type": "module"
   },
   "browser_specific_settings": {
      "gecko": {
         "id": "betterlyrics@boidu.dev",
         "strict_min_version": "100.0"
      }
   },
   "content_scripts": [ {
      "css": [  ],
      "js": [ "content_scripts/content-0.js" ],
      "matches": [ "*://music.youtube.com/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   }, {
      "css": [  ],
      "js": [ "earlyInject.js", "fix_config.js" ],
      "matches": [ "*://music.youtube.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "css": [  ],
      "js": [ "script.js" ],
      "matches": [ "*://music.youtube.com/*" ],
      "run_at": "document_end",
      "world": "MAIN"
   } ],
   "description": "Enhance YouTube Music with beautiful time-synced lyrics, multilingual support, real-time translations and more",
   "homepage_url": "https://better-lyrics.boidu.dev",
   "host_permissions": [ "*://music.youtube.com/*" ],
   "icons": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "512": "icons/icon-512.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Better Lyrics (Lyrics for Youtube Music)",
   "options_ui": {
      "open_in_tab": false,
      "page": "options_ui/page.html"
   },
   "permissions": [ "storage" ],
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "2.1.3",
   "version_name": "2.1.3",
   "web_accessible_resources": [ {
      "matches": [ "*://music.youtube.com/*" ],
      "resources": [ "*.js.map", "css/blyrics.css", "css/disablestylizedanimations.css", "css/themes/*.css", "css/themesong.css", "css/ytmusic.css", "pages/standalone-editor.html" ]
   } ]
}
