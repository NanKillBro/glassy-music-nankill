{
   "action": {
      "default_icon": "/Images/icon16.png",
      "default_popup": "popup.html"
   },
   "author": "Michael Ren",
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content_loader.js" ],
      "matches": [ "https://www.youtube.com/*", "https://music.youtube.com/*" ]
   } ],
   "description": "An extension used to create a detailed rich presence for YouTube videos on Discord.",
   "icons": {
      "128": "/Images/icon128.png",
      "16": "/Images/icon16.png",
      "48": "/Images/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "YouTubeDiscordPresence",
   "permissions": [ "nativeMessaging", "background", "storage", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.7.0",
   "web_accessible_resources": [ {
      "matches": [ "https://www.youtube.com/*", "https://music.youtube.com/*" ],
      "resources": [ "content.js", "warning.html" ]
   } ]
}
